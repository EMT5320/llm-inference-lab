# Normalize line endings: text files check out with LF and are stored with LF.
* text=auto eol=lf

# Explicitly treat common source/text types as text with LF.
*.py    text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.jsonl text eol=lf

# Windows-only scripts keep CRLF.
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Treat common binary artifacts as binary (no EOL conversion, no diff).
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.whl   binary
*.parquet binary
*.bin   binary
*.pt    binary
*.safetensors binary
